# Pyprland configuration
# Generated by pypr-quickstart
# 2026-06-11 18:00:56 UTC

[pyprland]
plugins = ["scratchpads"]

[scratchpads]

[scratchpads.termpad]
command = "kitty --class=termpad"
class = "termpad"
animation = "fromTop"
size = "65% 55%"
multi = false
pinned = false
hide_delay = 0
allow_special_workspaces = false
match_by = "class"
margin = 250
offset = "125px"
force_monitor = "DP-2"
lazy = true

[scratchpads.vimpad]
command = "kitty --class=vimpad -e nvim"
class = "vimpad"
animation = "fromTop"
size = "65% 55%"
multi = false
pinned = false
hide_delay = 0
allow_special_workspaces = false
match_by = "class"
margin = 250
offset = "120px"
force_monitor = "DP-2"
lazy = true

[scratchpads.nautipad]
command = "nautilus"
class = "org.gnome.Nautilus"
animation = "fromTop"
size = "65% 55%"
multi = false
pinned = false
hide_delay = 0
allow_special_workspaces = false
match_by = "class"
offset = "125px"
margin = 250
force_monitor = "DP-2"

[scratchpads.HyprThemer]
command = "python3 /usr/local/bin/themer.py"
class = "themer.py"
animation = "fromTop"
size = "65% 55%"
margin = 250
offset = "125px"
pinned = false
multi = false
hide_delay = 0
allow_special_workspaces = false
match_by = "class"
force_monitor = "DP-2"

[scratchpads.HyprBinds]
command = "python3 /usr/local/bin/binds.py"
class = "binds.py"
animation = "fromTop"
size = "65% 55%"
margin = 250
offset = "125px"
pinned = false
multi = false
hide_delay = 0
allow_special_workspaces = true
match_by = "class"
force_monitor = "DP-2"
unfocus = "empty"
process_tracking = false

[scratchpads.codipad]
command = "codium"
class = "codium"
animation = "fromTop"
size = "65% 55%"
margin = 250
offset = "125px"
multi = false
pinned = false
hide_delay = 0
allow_special_workspaces = false
match_by = "class"
process_tracking = false
force_monitor = "DP-2"

[scratchpads.pyprpad]
command = "chromium --app=http://127.0.0.1:18099"
animation = "fromTop"
size = "65% 55%"
margin = 250
offset = "125px"
pinned = false
multi = false
allow_special_workspaces = false
match_by = "title"
title = "pypr-gui"
force_monitor = "DP-2"

[scratchpads.quranpad]
command = "chromium --app=https://www.quranwbw.com"
class = "chrome-www.quranwbw.com__-Default"
animation = "fromTop"
size = "65% 55%"
margin = 250
offset = "125px"
pinned = false
multi = false
hide_delay = 0
allow_special_workspaces = false
match_by = "class"
process_tracking = false

[shortcuts_menu]
