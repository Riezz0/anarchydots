# Pyprland configuration
# Generated by pypr-quickstart
# 2026-06-07 11:06:48 UTC

[pyprland]
plugins = ["scratchpads"]

[scratchpads]

[scratchpads.termpad]
command = "kitty --class=termpad"
class = "termpad"
animation = "fromTop"
size = "65% 55%"
multi = false
pinned = false
hide_delay = 0
allow_special_workspaces = false
match_by = "class"
margin = 250
offset = "125%"

[scratchpads.vimpad]
command = "kitty --class=vimpad -e nvim"
class = "vimpad"
animation = "fromTop"
size = "65% 55"
pinned = false
multi = false
allow_special_workspaces = false
match_by = "class"
hide_delay = 0
margin = 250
offset = "120"
process_tracking = false

[shortcuts_menu]
