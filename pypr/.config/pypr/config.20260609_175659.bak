# Pyprland configuration
# Generated by pypr-quickstart
# 2026-06-09 17:56:42 UTC

[pyprland]
plugins = ["scratchpads"]

[scratchpads]

[scratchpads.termpad]
command = "kitty --class=termpad"
class = "termpad"
animation = "fromTop"
size = "65% 55%"
multi = false
pinned = false
hide_delay = 0
allow_special_workspaces = false
match_by = "class"
margin = 250
offset = "125%"

[scratchpads.vimpad]
command = "kitty --class=vimpad -e nvim"
class = "vimpad"
animation = "fromTop"
size = "65% 55%"
multi = false
pinned = false
hide_delay = 0
allow_special_workspaces = false
match_by = "class"
margin = 250
offset = "120"

[scratchpads.nautipad]
command = "nautilus"
class = "org.gnome.Nautilus"
animation = "fromTop"
size = "65% 55%"
multi = false
pinned = false
hide_delay = 0
allow_special_workspaces = false
match_by = "class"
offset = "125%"
margin = 250

[scratchpads.HyprThemer]
command = "python3 /usr/local/bin/themer.py"
class = "themer.py"
animation = "fromTop"
size = "65% 55%"
margin = 250
offset = "125"
pinned = false
multi = false
hide_delay = 0
allow_special_workspaces = false
match_by = "class"

[scratchpads.HyprBinds]
command = "python3 /usr/local/bin/binds.py"
class = "binds.py"
animation = "fromTop"
size = "65% 55%"
margin = 250
offset = "125"
pinned = false
multi = false
hide_delay = 0
allow_special_workspaces = false
match_by = "class"

[scratchpads.codipad]
command = "codium"
class = "codium"
animation = "fromTop"
size = "65% 55%"
margin = 250
offset = "125%"
multi = false
pinned = false
hide_delay = 0
allow_special_workspaces = false
match_by = "class"
process_tracking = false

[scratchpads.pyprpad]
command = "chromium --app=http://127.0.0.1:18099"
animation = "fromTop"
size = "65% 55"
margin = 250
offset = "125"
pinned = false
multi = false
allow_special_workspaces = false
match_by = "title"
title = "pypr-gui"

