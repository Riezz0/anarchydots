# Pyprland configuration
# Generated by pypr-quickstart
# 2026-06-09 15:57:45 UTC

[pyprland]
plugins = ["scratchpads"]

[scratchpads]

[scratchpads.termpad]
command = "kitty --class=termpad"
class = "termpad"
animation = "fromTop"
size = "65% 55%"
multi = false
pinned = false
hide_delay = 0
allow_special_workspaces = false
match_by = "class"
margin = 250
offset = "125%"

[scratchpads.vimpad]
command = "kitty --class=vimpad -e nvim"
class = "vimpad"
animation = "fromTop"
size = "65% 55%"
multi = false
pinned = false
hide_delay = 0
allow_special_workspaces = false
match_by = "class"
margin = 250
offset = "120"

[scratchpads.nautipad]
command = "nautilus"
class = "org.gnome.Nautilus"
animation = "fromTop"
size = "65% 55%"
multi = false
pinned = false
hide_delay = 0
allow_special_workspaces = false
match_by = "class"
offset = "125%"
margin = 250

[shortcuts_menu]
