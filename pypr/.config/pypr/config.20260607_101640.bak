# Pyprland configuration
# Generated by pypr-quickstart
# 2026-06-07 10:11:11 UTC

[pyprland]
plugins = ["scratchpads"]

[scratchpads]

[scratchpads.termpad]
command = "kitty --class=termpad"
class = "termpad"
animation = "fromTop"
size = "65% 55%"
multi = false
pinned = false
hide_delay = 0
allow_special_workspaces = false
match_by = "class"
margin = 250
offset = "125%"


