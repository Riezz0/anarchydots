tooltip label {
  color: @foreground;                   
  font-family: "MesloLGL Nerd Font";    
  font-size: 12px;
  padding: 0px;
}

tooltip {
  background: alpha(@background, 1); 
  border: 2px solid @color8;        
  border-radius: 0px;               
}

